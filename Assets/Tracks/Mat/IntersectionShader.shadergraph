{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "652d27ec71f94e5b93916490c1dfadf5",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "Hexgrid (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 121.49999237060547,
            "y": 1085.9998779296875,
            "width": 252.49996948242188,
            "height": 214.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "4ee20cbe27574a508621575fb7da5ecc"
        },
        {
            "m_Id": "267f7dacb08f401db76a58f7337fa3db"
        },
        {
            "m_Id": "3510d13e6bf14ba0b2eebcbcd425154d"
        },
        {
            "m_Id": "4aa8a8c33bb541e38546392935709233"
        },
        {
            "m_Id": "3656a25702a343bcb3b0ca67343b24c9"
        },
        {
            "m_Id": "13eae131317d4807aec976a9d2e401cc"
        },
        {
            "m_Id": "7bbf1d9f18c147c3a75eb492377495d6"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "Hexgrid",
    "m_FunctionSource": "267cd9b17326149899e8c08bcd03083a",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 p = UV_Vector * Scale;\n\n// Proper hex tiling basis\nfloat2 r = float2(1.0, 1.7320508);\nfloat2 h = r * 0.5;\n\n// Two offset grids, pick nearest hex center\nfloat2 a = fmod(p, r) - h;\nfloat2 b = fmod(p - h, r) - h;\n\nfloat useB = step(dot(b, b), dot(a, a));\nfloat2 gv = lerp(a, b, useB);\n\n// Hex distance field\nfloat2 q = abs(gv);\n\n// Correct flat-top hex distance\nfloat hexDist = max(dot(q, float2(0.5, 0.8660254)), q.x);\n\n// Distance to shared hex boundary\nfloat edgeDist = 0.5 - hexDist;\n\n// Anti-aliasing\nfloat aa = max(fwidth(edgeDist), 0.001);\n\n// TRUE honeycomb shared line\nfloat honeycombLine = 1.0 - smoothstep(Line_Width, Line_Width + aa, abs(edgeDist));\n\n// Optional inner hex line\nfloat inner = clamp(Inner_Size_Float, 0.0, 0.95);\nfloat innerEdge = 0.5 * inner - hexDist;\nfloat innerLine = 1.0 - smoothstep(Line_Width, Line_Width + aa, abs(innerEdge));\n\n// Pattern mode:\n// 0 = shared honeycomb grid\n// 1 = internal isolated hex line\nfloat mode = clamp(Pattern_Mode_Float, 0.0, 1.0);\nfloat mask = lerp(honeycombLine, innerLine, mode);\n\n// Invert\nfloat inv = clamp(Invert_Float, 0.0, 1.0);\nmask = lerp(mask, 1.0 - mask, inv);\n\nOut_Float = mask;"
}

